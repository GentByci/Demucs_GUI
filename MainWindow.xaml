<Window x:Class="DemucsGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Demucs Studio"
        Height="700" Width="520"
        MinHeight="600"
        Background="#0A0908"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>

        <!--
        ╔══════════════════════════════════════════════════════════════╗
        ║  CINEMA GRADE  —  Teal × Ember                              ║
        ║                                                              ║
        ║  Inspired by the teal-orange split used in film colour       ║
        ║  grading. Warm charcoal base lets both ends of the           ║
        ║  spectrum breathe without competing.                         ║
        ║                                                              ║
        ║  Surface  #0A0908  warm near-black charcoal                  ║
        ║  Card     #141210  lifted warm dark                          ║
        ║  Border   #282420  subtle warm rim                           ║
        ║  Orange   #FF8200  primary CTA / active state               ║
        ║  Teal     #00C896  success / GPU / data indicators           ║
        ║  Gold     #FFC100  code text / progress / numbers            ║
        ║  Cream    #F2EDE8  high-contrast body text                   ║
        ║  Ash      #706860  secondary / placeholder text              ║
        ╚══════════════════════════════════════════════════════════════╝
        -->

        <SolidColorBrush x:Key="BrushOrange"  Color="#007c5d    "/>
        <SolidColorBrush x:Key="BrushTeal"    Color="#00C896"/>
        <SolidColorBrush x:Key="BrushGold"    Color="#FFC100"/>
        <SolidColorBrush x:Key="BrushCard"    Color="#141210"/>
        <SolidColorBrush x:Key="BrushBorder"  Color="#282420"/>
        <SolidColorBrush x:Key="BrushSurface" Color="#0A0908"/>
        <SolidColorBrush x:Key="BrushTextHi"  Color="#F2EDE8"/>
        <SolidColorBrush x:Key="BrushAsh"     Color="#706860"/>

        <!-- Card -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background"      Value="#141210"/>
            <Setter Property="BorderBrush"     Value="#282420"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Padding"         Value="18,14"/>
        </Style>

        <!-- Primary button: orange, dark text, brightens toward gold on hover -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"       Value="#007c5d"/>
            <Setter Property="Foreground"       Value="#0A0908"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FontWeight"       Value="Bold"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF9C20"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D96B00"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#282420"/>
                                <Setter Property="Foreground" Value="#706860"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ghost button: teal border on hover (complementary to orange) -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background"       Value="#1A1815"/>
            <Setter Property="Foreground"       Value="#8A8278"/>
            <Setter Property="BorderBrush"      Value="#282420"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#1F1E1A"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00C896"/>
                                <Setter Property="Foreground" Value="#F2EDE8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Text box: teal focus ring, orange caret -->
        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Background"       Value="#0A0908"/>
            <Setter Property="Foreground"       Value="#F2EDE8"/>
            <Setter Property="BorderBrush"      Value="#282420"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="12,9"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="CaretBrush"       Value="#FF8200"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00C896"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle chip: orange when active, teal ring on hover -->
        <Style x:Key="ToggleChip" TargetType="ToggleButton">
            <Setter Property="Background"       Value="#141210"/>
            <Setter Property="Foreground"       Value="#706860"/>
            <Setter Property="BorderBrush"      Value="#282420"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="16,10"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#121e1b   "/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#007c5d"/>
                                <Setter Property="Foreground" Value="#F2EDE8"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00C896"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section label -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#706860"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,10"/>
        </Style>

    </Window.Resources>

    <!-- Outer shell: warm charcoal, teal-to-orange gradient rim -->
    <Border Background="#0A0908" CornerRadius="14">
        <Border.BorderThickness>1</Border.BorderThickness>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#00C896" Offset="0.0"/>
                <GradientStop Color="#282420" Offset="0.4"/>
                <GradientStop Color="#282420" Offset="0.6"/>
                <GradientStop Color="#FF8200" Offset="1.0"/>
            </LinearGradientBrush>
        </Border.BorderBrush>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ═══════════════════════════════════════════════ TITLE BAR -->
            <Border Grid.Row="0" Background="#0A0908" CornerRadius="14,14,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border.BorderThickness>0,0,0,1</Border.BorderThickness>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1A2E28" Offset="0.0"/>
                        <GradientStop Color="#282420" Offset="0.35"/>
                        <GradientStop Color="#282420" Offset="0.65"/>
                        <GradientStop Color="#2E1E00" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>

                <Grid Margin="18,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo + title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Badge: teal icon square, feels like a DAW plugin logo -->
                        <Border Width="28" Height="28" CornerRadius="7" Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#00C896" Offset="0"/>
                                    <GradientStop Color="#00A070" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="D" Foreground="#0A0908" FontWeight="Black"
                                       FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="demucs" Foreground="#F2EDE8" FontSize="15"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text=" studio" Foreground="#5A7870" FontSize="15" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,2,0">
                        <Button Width="12" Height="12" Margin="0,0,8,0" Cursor="Hand"
                                ToolTip="Minimize" Click="MinimizeButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Ellipse Fill="#FFC100" Width="12" Height="12"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Width="12" Height="12" Cursor="Hand" ToolTip="Close" Click="CloseButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Ellipse Fill="#FF4D4D" Width="12" Height="12"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════ CONTENT -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="18,12,18,24">

                    <!-- INPUT FILE ──────────────────────────────────── -->
                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="INPUT FILE" Style="{StaticResource SectionLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="InputPathBox" Grid.Column="0"
                                         Style="{StaticResource InputTextBox}"
                                         IsReadOnly="True" Foreground="#706860"
                                         Text="No file selected..."/>
                                <Button Grid.Column="2" Content="Browse"
                                        Style="{StaticResource GhostButton}"
                                        Padding="14,9" Click="BrowseInput_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- OUTPUT FOLDER ───────────────────────────────── -->
                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="OUTPUT FOLDER" Style="{StaticResource SectionLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="OutputPathBox" Grid.Column="0"
                                         Style="{StaticResource InputTextBox}"
                                         IsReadOnly="True" Foreground="#706860"
                                         Text="No folder selected..."/>
                                <Button Grid.Column="2" Content="Browse"
                                        Style="{StaticResource GhostButton}"
                                        Padding="14,9" Click="BrowseOutput_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- SEPARATION MODE ─────────────────────────────── -->
                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="SEPARATION MODE" Style="{StaticResource SectionLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ToggleButton x:Name="FullSepToggle" Grid.Column="0"
                                              Style="{StaticResource ToggleChip}"
                                              IsChecked="True" Click="SeparationMode_Click" Grid.ColumnSpan="2" Margin="0,0,8,0" Height="54" VerticalAlignment="Bottom">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="Full Separation" FontSize="12"
                                                   FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Vocals · Drums · Bass · Other"
                                                   FontSize="10" Foreground="#706860"
                                                   HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </ToggleButton>
                                <ToggleButton x:Name="TwoStemToggle" Grid.Column="2"
                                              Style="{StaticResource ToggleChip}"
                                              Click="SeparationMode_Click">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="2-Stem Split" FontSize="12"
                                                   FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Vocals · Instrumental"
                                                   FontSize="10" Foreground="#706860"
                                                   HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </ToggleButton>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- MODEL + DEVICE ──────────────────────────────── -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Model -->
                        <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="MODEL" Style="{StaticResource SectionLabel}"/>
                                <ComboBox x:Name="ModelSelector"
                                          Foreground="#F2EDE8" Background="#0A0908"
                                          BorderBrush="#282420" BorderThickness="1"
                                          Padding="10,7" FontSize="12">
                                    <ComboBoxItem Content="htdemucs"    IsSelected="True"/>
                                    <ComboBoxItem Content="htdemucs_ft"/>
                                    <ComboBoxItem Content="htdemucs_6s"/>
                                    <ComboBoxItem Content="hdemucs_mmi"/>
                                    <ComboBoxItem Content="mdx"/>
                                    <ComboBoxItem Content="mdx_extra"/>
                                    <ComboBoxItem Content="mdx_q"/>
                                    <ComboBoxItem Content="mdx_extra_q"/>
                                </ComboBox>
                                <TextBlock x:Name="ModelDescription"
                                           Text="Default hybrid transformer model"
                                           Foreground="#706860" FontSize="10"
                                           TextWrapping="Wrap" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Device -->
                        <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="DEVICE" Style="{StaticResource SectionLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="CpuToggle" Grid.Column="0"
                                                  Style="{StaticResource ToggleChip}"
                                                  IsChecked="True" Click="DeviceMode_Click">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="CPU" FontSize="12" FontWeight="Bold"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="Slower" FontSize="10" Foreground="#706860"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </ToggleButton>
                                    <ToggleButton x:Name="GpuToggle" Grid.Column="2"
                                                  Style="{StaticResource ToggleChip}"
                                                  Click="DeviceMode_Click">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="GPU" FontSize="12" FontWeight="Bold"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="Faster" FontSize="10" Foreground="#706860"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </ToggleButton>
                                </Grid>
                                <!-- GPU status: teal when detected -->
                                <TextBlock x:Name="DeviceStatus" Text="Checking GPU..."
                                           Foreground="#706860" FontSize="10" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- COMMAND PREVIEW ─────────────────────────────── -->
                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="COMMAND PREVIEW" Style="{StaticResource SectionLabel}"/>
                            <!-- Terminal-style inner box with teal left accent bar -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="2,0,0,2">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#00C896" Offset="0"/>
                                            <GradientStop Color="#FF8200" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Border Grid.Column="1" Background="#0A0908"
                                        BorderBrush="#282420" BorderThickness="0,1,1,1"
                                        CornerRadius="0,8,8,0" Padding="12,10">
                                    <TextBlock x:Name="CommandPreview"
                                               Text="demucs -n htdemucs -d cpu ..."
                                               Foreground="#FFC100" FontFamily="Consolas"
                                               FontSize="11" TextWrapping="Wrap"/>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- PROGRESS CARD ───────────────────────────────── -->
                    <Border x:Name="ProgressCard" Style="{StaticResource CardBorder}"
                            Margin="0,0,0,8" Visibility="Collapsed">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="PROCESSING" Foreground="#706860"
                                           FontSize="10" FontWeight="SemiBold"/>
                                <!-- Percent in teal when running, gold when done -->
                                <TextBlock x:Name="ProgressPercent" Text="0%"
                                           Foreground="#00C896" FontSize="10"
                                           FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            </Grid>
                            <!-- Track: dark groove -->
                            <Border x:Name="ProgressTrack" Background="#0A0908"
                                    CornerRadius="3" Height="4">
                                <!-- Fill: teal → gold gradient (left cold, right warm) -->
                                <Border x:Name="ProgressFill" CornerRadius="3"
                                        HorizontalAlignment="Left" Width="0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00C896" Offset="0.0"/>
                                            <GradientStop Color="#FFC100" Offset="0.6"/>
                                            <GradientStop Color="#FF8200" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Border>
                            <TextBlock x:Name="StatusText" Text="Initializing..."
                                       Foreground="#706860" FontSize="11"
                                       TextWrapping="Wrap" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- LIVE LOG ────────────────────────────────────── -->
                    <Border x:Name="LogPanel" Style="{StaticResource CardBorder}"
                            Margin="0,0,0,8" Visibility="Collapsed">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="OUTPUT LOG" Foreground="#706860"
                                           FontSize="10" FontWeight="SemiBold"/>
                                <TextBlock Text="%TEMP%\demucs_gui.log"
                                           Foreground="#383430" FontSize="10"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                            <!-- Terminal box: same left-accent treatment as command preview -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#00C896" CornerRadius="2,0,0,2"/>
                                <Border Grid.Column="1" Background="#0A0908"
                                        BorderBrush="#282420" BorderThickness="0,1,1,1"
                                        CornerRadius="0,6,6,0" Padding="10,8">
                                    <TextBox x:Name="LogBox" Background="Transparent"
                                             Foreground="#7DCEBA" FontFamily="Consolas"
                                             FontSize="10" BorderThickness="0"
                                             IsReadOnly="True" TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto" Height="120"
                                             FocusVisualStyle="{x:Null}"/>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- RUN BUTTON ──────────────────────────────────── -->
                    <Button x:Name="RunButton" Content="Separate Track"
                            Style="{StaticResource PrimaryButton}"
                            Height="46" FontSize="14" Padding="20,12"
                            Click="RunButton_Click"/>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
